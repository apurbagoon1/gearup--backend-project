model User {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  password    String
  phone       String?
  photo       String?

  role        Role
  status      UserStatus @default(ACTIVE)

  gears       Gear[]
  rentals     RentalOrder[]
  reviews     Review[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Role {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}
